# Application environment: development | production
FLASK_ENV=development

# Flask / JWT secrets (change these in real environments)
SECRET_KEY=change-me-secret-key
JWT_SECRET_KEY=change-me-jwt-secret-key

# Legacy alias still supported by config (optional if SECRET_KEY is set)
MY_SECRET_KEY=change-me-secret-key

# Internal API key for ingestion endpoints (X-API-Key header)
API_KEY=change-me-internal-api-key

# Database URIs
# Development (default: sqlite:///dev.db in project root)
DEV_DATABASE_URI=sqlite:///dev.db

# Production (example MySQL)
# PROD_DATABASE_URI=mysql+pymysql://user:password@localhost:3306/ies_monitoring
PROD_DATABASE_URI=sqlite:///prod.db
